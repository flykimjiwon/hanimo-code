{
  // hanimo (하니모) 설정 파일
  // 이 파일을 ~/.hanimo/config.json 에 복사하여 사용하세요

  // 기본 프로바이더 (openai, anthropic, google, ollama, custom 등)
  "provider": "ollama",

  // 기본 모델
  "model": "qwen3:8b",

  // 프로바이더별 API 키 설정
  "providers": {
    // "openai": { "apiKey": "sk-..." },
    // "anthropic": { "apiKey": "sk-ant-..." },
    // "google": { "apiKey": "AI..." }
  },

  // === Custom Provider (직접 추가) ===
  // OpenAI 호환 API 서버라면 어디든 연결 가능
  "customProviders": [
    // 예시 1: 사내 GPU 서버
    // {
    //   "name": "my-gpu-server",
    //   "baseURL": "http://192.168.1.100:8000/v1",
    //   "models": ["llama-3.1-70b", "qwen2.5-coder-32b"]
    // },
    //
    // 예시 2: API 키가 필요한 외부 서비스
    // {
    //   "name": "my-cloud-api",
    //   "baseURL": "https://api.example.com/v1",
    //   "apiKey": "your-api-key-here",
    //   "models": ["model-name-1", "model-name-2"]
    // },
    //
    // 예시 3: vLLM / TGI 등 로컬 서버
    // {
    //   "name": "local-vllm",
    //   "baseURL": "http://localhost:8000/v1",
    //   "models": ["meta-llama/Llama-3.1-8B-Instruct"]
    // }
  ],

  // === 멀티 엔드포인트 (여러 서버 동시 연결) ===
  "endpoints": [
    // {
    //   "name": "local-ollama",
    //   "provider": "ollama",
    //   "baseURL": "http://localhost:11434",
    //   "priority": 10
    // },
    // {
    //   "name": "remote-gpu",
    //   "provider": "custom",
    //   "baseURL": "https://your-server.com/v1",
    //   "apiKey": "optional-key",
    //   "priority": 5
    // }
  ],

  // 셸 실행 설정
  "shell": {
    "timeout": 30000,
    "requireApproval": true
  },

  // 에이전트 최대 스텝
  "maxSteps": 25,

  // 기본 역할 (dev, plan, chat)
  "defaultRole": "dev",

  // MCP 서버 연결
  "mcp": {
    "servers": {
      // "example-server": {
      //   "name": "example",
      //   "command": "npx",
      //   "args": ["-y", "some-mcp-server"],
      //   "enabled": true
      // }
    }
  }
}
