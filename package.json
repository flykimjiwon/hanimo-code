{
  "name": "modol",
  "version": "0.1.0",
  "description": "modol — cute terminal-based AI coding assistant",
  "type": "module",
  "bin": {
    "modol": "./bin/modol.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "start": "node dist/cli.js",
    "bundle": "node scripts/build-binary.mjs",
    "build:binary": "npm run bundle && bash scripts/build-sea.sh"
  },
  "keywords": [
    "ai",
    "coding-assistant",
    "terminal",
    "multi-agent",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/google": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "ai": "^4.0.0",
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "globby": "^14.0.0",
    "ink": "^5.0.0",
    "react": "^18.3.0",
    "simple-git": "^3.24.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.57.2",
    "esbuild": "^0.24.0",
    "postject": "^1.0.0-alpha.6",
    "vitest": "^2.0.0"
  }
}
